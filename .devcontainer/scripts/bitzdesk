#!/usr/bin/env bash
set -Eeuo pipefail

# In Codespaces, the workspace is at /workspaces/<repo>
# If we're in a Codespace, prefer that path for scripts
if [ -d "/workspaces/bitzdesk/.devcontainer/scripts" ]; then
    SCRIPT_DIR="/workspaces/bitzdesk/.devcontainer/scripts"
else
    ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    SCRIPT_DIR="$ROOT/.devcontainer/scripts"
fi

# Fallback if running outside the repository or workspace
if [ ! -d "$SCRIPT_DIR" ]; then
    SCRIPT_DIR="$HOME/.bitzdesk/scripts"
fi

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

banner() {
    echo -e "${BLUE}"
    echo "=========================================="
    echo "              BitzDesk CLI"
    echo "=========================================="
    echo -e "${NC}"
}

usage() {
    banner
    cat <<EOF

Usage:

  bitzdesk setup
  bitzdesk doctor
  bitzdesk start
  bitzdesk stop
  bitzdesk restart
  bitzdesk tunnel
  bitzdesk update
  bitzdesk status
  bitzdesk logs
  bitzdesk brave
  bitzdesk firefox

EOF
}

run_script() {
    local script="$SCRIPT_DIR/$1"

    if [ ! -f "$script" ]; then
        echo -e "${RED}Missing script:${NC} $script"
        exit 1
    fi

    bash "$script"
}

case "${1:-help}" in

setup)
    run_script setup-vnc.sh
    run_script install-ai-tools.sh
    run_script patch-brave.sh
    ;;

doctor)
    run_script healthcheck.sh
    ;;

start)
    run_script setup-vnc.sh
    run_script start-vnc.sh
    ;;

stop)
    run_script stop-vnc.sh
    ;;

restart)
    run_script stop-vnc.sh
    sleep 2
    run_script start-vnc.sh
    ;;

tunnel)
    run_script tunnel.sh
    ;;

update)
    echo
    echo "Updating AI tools..."

    if command -v npm >/dev/null 2>&1; then
        npm update -g @openai/codex || true
        npm update -g @google/gemini-cli || true
    fi

    curl -fsSL https://opencode.ai/install | bash || true
    curl -fsSL https://antigravity.google/cli/install.sh | bash || true

    echo
    echo "Finished."
    ;;

status)
    echo
    echo "===== VNC ====="
    vncserver -list || true

    echo
    echo "===== Port ====="
    ss -ltn 2>/dev/null | grep 5901 || true

    echo
    echo "===== Processes ====="
    ps aux | grep Xtigervnc | grep -v grep || true
    ;;

logs)
    if ls ~/.vnc/*.log >/dev/null 2>&1; then
        tail -100 ~/.vnc/*.log
    else
        echo "No VNC logs found."
    fi
    ;;

brave)
    if command -v brave >/dev/null 2>&1; then
        brave
    elif command -v brave-browser >/dev/null 2>&1; then
        brave-browser
    else
        echo "Brave Browser is not installed."
    fi
    ;;

firefox)
    if command -v firefox >/dev/null 2>&1; then
        firefox
    else
        echo "Firefox is not installed."
    fi
    ;;

help|-h|--help)
    usage
    ;;

*)
    usage
    exit 1
    ;;

esac